<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================= -->
    <!--          COULEURS UI          -->
    <!-- ============================= -->

    <SolidColorBrush x:Key="FondPrincipalBrush" Color="#1F2933"/>
    <SolidColorBrush x:Key="FondSecondaireBrush" Color="#243447"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2980B9"/>

    <SolidColorBrush x:Key="TextePrincipalBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="TexteSecondaireBrush" Color="#95A5A6"/>


    <!-- ============================= -->
    <!--       COULEURS ÉCHIQUIER      -->
    <!-- ============================= -->

    <SolidColorBrush x:Key="CaseClaireBrush" Color="#F0D9B5"/>
    <SolidColorBrush x:Key="CaseFonceeBrush" Color="#B58863"/>
    <SolidColorBrush x:Key="CaseSelectionneeBrush" Color="#FFE082"/>
    <SolidColorBrush x:Key="CasePossibleBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="CaseEchecBrush" Color="#E57373"/>
    <SolidColorBrush x:Key="CaseDernierCoupBrush" Color="#FFF59D"/>


    <!-- ============================= -->
    <!--         STYLES GLOBAUX        -->
    <!-- ============================= -->

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextePrincipalBrush}"/>
        <Setter Property="Background" Value="{StaticResource FondPrincipalBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextePrincipalBrush}"/>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource TexteSecondaireBrush}"/>
        <Setter Property="Margin" Value="5"/>
    </Style>


    <!-- ============================= -->
    <!--         STYLE DES BOUTONS     -->
    <!-- ============================= -->

    <Style TargetType="Button">
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BorderButton"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BorderButton"
                                    Property="Background"
                                    Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BorderButton"
                                    Property="Opacity"
                                    Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
