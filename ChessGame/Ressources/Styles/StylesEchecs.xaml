<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ============================= -->
	<!--      COULEURS PRINCIPALES     -->
	<!-- ============================= -->

	<SolidColorBrush x:Key="FondPrincipalBrush" Color="#1F2933"/>
	<SolidColorBrush x:Key="FondSecondaireBrush" Color="#243447"/>
	<SolidColorBrush x:Key="AccentBrush" Color="#3A7AFE"/>
	<SolidColorBrush x:Key="AccentHoverBrush" Color="#5A8AFE"/>

	<SolidColorBrush x:Key="TextePrincipalBrush" Color="#ECF0F1"/>
	<SolidColorBrush x:Key="TexteSecondaireBrush" Color="#95A5A6"/>


	<!-- ============================= -->
	<!--       ECOULEURS ÉCHIQUIER     -->
	<!-- ============================= -->

	<SolidColorBrush x:Key="CaseClaireBrush" Color="#F0D9B5" />
	<SolidColorBrush x:Key="CaseFonceeBrush" Color="#B58863" />
	<SolidColorBrush x:Key="CaseSelectionneeBrush" Color="#66A5FF" />
	<SolidColorBrush x:Key="CasePossibleBrush" Color="#55FFEB3B" />
	<SolidColorBrush x:Key="CaseDernierCoupBrush" Color="#88FFD700" />
	<SolidColorBrush x:Key="CaseEchecBrush" Color="#88FF0000" />


	<!-- ============================= -->
	<!--     STYLE DES FENÊTRES       -->
	<!-- ============================= -->

	<Style TargetType="Window">
		<Setter Property="FontFamily" Value="Segoe UI"/>
		<Setter Property="TextElement.FontSize" Value="14"/>
		<Setter Property="Foreground" Value="{StaticResource TextePrincipalBrush}"/>
		<Setter Property="Background" Value="{StaticResource FondPrincipalBrush}"/>
	</Style>


	<!-- ============================= -->
	<!--   STYLE BOUTONS MODERNES      -->
	<!-- ============================= -->

	<Style TargetType="Button" x:Key="BoutonPrincipal">
		<Setter Property="Padding" Value="10,6"/>
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="Margin" Value="4"/>
		<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Cursor" Value="Hand"/>

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">

						<ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

					</Border>

					<ControlTemplate.Triggers>

						<!-- Hover -->
						<Trigger Property="IsMouseOver" Value="True">
							<Setter Property="Background"
                                    Value="{StaticResource AccentHoverBrush}"/>
						</Trigger>

						<!-- Disabled -->
						<Trigger Property="IsEnabled" Value="False">
							<Setter Property="Opacity" Value="0.5"/>
						</Trigger>

					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
