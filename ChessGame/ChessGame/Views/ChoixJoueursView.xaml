<UserControl x:Class="ChessGame.Views.ChoixJoueursView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">

    <Grid Background="#1E1E1E" Margin="40">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITRE -->
        <TextBlock Text="Choix des joueurs"
                   FontSize="32"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0 0 0 25"
                   HorizontalAlignment="Center"/>

        <!-- JOUEUR BLANC -->
        <StackPanel Grid.Row="1" Margin="0 15">
            <TextBlock Text="Joueur Blanc" 
                       Foreground="White" 
                       FontSize="18"/>
            <TextBox x:Name="TxtBlanc"
                     Height="40"
                     FontSize="18"
                     Margin="0 5 0 0"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="Gray"/>
        </StackPanel>

        <!-- JOUEUR NOIR -->
        <StackPanel Grid.Row="2" Margin="0 15">
            <TextBlock Text="Joueur Noir" 
                       Foreground="White" 
                       FontSize="18"/>
            <TextBox x:Name="TxtNoir"
                     Height="40"
                     FontSize="18"
                     Margin="0 5 0 0"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="Gray"/>
        </StackPanel>

        <!-- BOUTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 40 0 0">

            <!-- Bouton Retour -->
            <Button Content="Retour"
                    Width="120"
                    Height="45"
                    FontSize="16"
                    Click="BtnRetour_Click"
                    Background="#444"
                    Foreground="White"
                    Margin="0 0 20 0"/>

            <!-- Bouton Démarrer -->
            <Button Content="Démarrer la partie"
                    Width="200"
                    Height="45"
                    FontSize="16"
                    Click="BtnDemarrer_Click"
                    Background="#3A8DFF"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

    </Grid>

</UserControl>
