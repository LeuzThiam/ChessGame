<UserControl x:Class="ChessGame.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#141414">

    <!-- =============== RESSOURCES (OBLIGATOIREMENT AVANT LE GRID) =============== -->
    <UserControl.Resources>
        <DropShadowEffect x:Key="TitleGlow"
                          Color="#3A7AFE"
                          BlurRadius="40"
                          ShadowDepth="0"
                          Opacity="0.6"/>

        <DropShadowEffect x:Key="GlowEffect"
                          Color="#2A5AFE"
                          BlurRadius="120"
                          ShadowDepth="0"
                          Opacity="0.3"/>
    </UserControl.Resources>

    <!-- ========================= CONTENU ========================= -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Halo décoratif -->
        <Ellipse Width="600" Height="600"
                 Fill="#2A5AFE22"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0 -250 0 0"
                 Effect="{StaticResource GlowEffect}"/>

        <!-- TITRE -->
        <TextBlock Text="CHESS GAME"
                   FontSize="64"
                   FontWeight="Black"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0 80 0 40"
                   Effect="{StaticResource TitleGlow}"/>

        <!-- BOUTONS -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0 40 0 0"
                    Width="350">

            <!-- Jouer -->
            <Border CornerRadius="14"
                    Margin="0 0 0 25"
                    Background="#2962FF">
                <Button Background="Transparent"
                        BorderBrush="{x:Null}"
                        Click="BtnJouer_Click"
                        Height="70"
                        FontSize="24"
                        Foreground="White">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ChessKnight"
                                                    Width="32" Height="32"
                                                    Margin="0 0 10 0"/>
                        <TextBlock Text="JOUER (1 vs 1)"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Quitter -->
            <Border CornerRadius="14"
                    Background="#333">
                <Button Background="Transparent"
                        BorderBrush="{x:Null}"
                        Click="BtnQuitter_Click"
                        Height="70"
                        FontSize="24"
                        Foreground="#E0E0E0">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ExitRun"
                                                    Width="32" Height="32"
                                                    Margin="0 0 10 0"/>
                        <TextBlock Text="QUITTER"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Border>

        </StackPanel>

    </Grid>
</UserControl>
