<Window x:Class="ChessGame.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ChessGame.Views"
        mc:Ignorable="d"
        Title="Jeu d'Échecs" 
        Height="720" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FondPrincipalBrush}">

    <Window.Resources>
        <!-- Styles spécifiques à cette fenêtre si nécessaire -->
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Zone principale avec l'échiquier -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <Border Grid.Row="0" 
                    Style="{StaticResource PanneauPrincipal}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="♔ Jeu d'Échecs ♚"
                               Style="{StaticResource TexteTitre}"
                               HorizontalAlignment="Center"
                               Margin="0,10"/>

                    <TextBlock Text="{Binding MessageStatut}"
                               Style="{StaticResource TexteNormal}"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,10"/>
                </StackPanel>
            </Border>

            <!-- Échiquier -->
            <Viewbox Grid.Row="1" 
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <views:EchiquierView DataContext="{Binding EchiquierViewModel}"/>
            </Viewbox>
        </Grid>

        <!-- Panneau d'information à droite -->
        <Border Grid.Column="1" 
                Width="320"
                Margin="0,20,20,20">
            <views:InfoPartieView DataContext="{Binding InfoPartieViewModel}"/>
        </Border>

        <!-- Menu -->
        <Menu Grid.ColumnSpan="2"
              VerticalAlignment="Top"
              Background="{StaticResource FondSecondaireBrush}"
              Foreground="{StaticResource TextePrincipalBrush}">

            <MenuItem Header="Fichier"
                      Foreground="{StaticResource TextePrincipalBrush}">
                <MenuItem Header="Nouvelle Partie" 
                          Command="{Binding CommandeNouvellePartie}"/>
                <MenuItem Header="Charger Partie" 
                          Command="{Binding CommandeChargerPartie}"/>
                <MenuItem Header="Sauvegarder Partie" 
                          Command="{Binding CommandeSauvegarderPartie}"/>
                <Separator/>
                <MenuItem Header="Quitter" 
                          Command="{Binding CommandeQuitter}"/>
            </MenuItem>

            <MenuItem Header="Partie"
                      Foreground="{StaticResource TextePrincipalBrush}">
                <MenuItem Header="Annuler Coup" 
                          Command="{Binding CommandeAnnulerCoup}"/>
                <MenuItem Header="Refaire Coup" 
                          Command="{Binding CommandeRefaireCoup}"/>
                <Separator/>
                <MenuItem Header="Proposer Nulle" 
                          Command="{Binding CommandeProposerNulle}"/>
                <MenuItem Header="Abandonner" 
                          Command="{Binding CommandeAbandonner}"/>
            </MenuItem>

            <MenuItem Header="Affichage"
                      Foreground="{StaticResource TextePrincipalBrush}">
                <MenuItem Header="Rotation Échiquier" 
                          Command="{Binding CommandeRotationEchiquier}"/>
                <MenuItem Header="Afficher Coordonnées" 
                          IsCheckable="True"
                          IsChecked="{Binding AfficherCoordonnees}"/>
                <MenuItem Header="Afficher Coups Possibles" 
                          IsCheckable="True"
                          IsChecked="{Binding AfficherCoupsPossibles}"/>
            </MenuItem>

            <MenuItem Header="Aide"
                      Foreground="{StaticResource TextePrincipalBrush}">
                <MenuItem Header="Règles du jeu" 
                          Command="{Binding CommandeAfficherRegles}"/>
                <MenuItem Header="À propos" 
                          Command="{Binding CommandeAPropos}"/>
            </MenuItem>
        </Menu>
    </Grid>
</Window>