<UserControl x:Class="ChessGame.Views.InfoPartieView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITRE -->
        <TextBlock Text="Informations sur la partie"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#FFFFFF"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <!-- JOUEURS -->
        <StackPanel Grid.Row="1" Margin="0 0 0 20">

            <!-- JOUEUR BLANC -->
            <Border Background="#2A2A2A"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0 0 0 12">

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <iconPacks:PackIconMaterial Kind="ChessKing"
                                                    Width="26" Height="26"
                                                    Foreground="White"/>
                        <TextBlock Text=" Joueur Blanc"
                                   FontSize="18"
                                   Foreground="#9BE6A7"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Nom :" Width="120" Foreground="#BDBDBD"/>
                        <TextBlock Text="{Binding NomJoueurBlanc}" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                        <TextBlock Text="Temps :" Width="120" Foreground="#BDBDBD"/>
                        <TextBlock Text="{Binding TempsJoueurBlanc}"
                                   Foreground="#A5FFB3"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- JOUEUR NOIR -->
            <Border Background="#262626"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0 0 0 12">

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <iconPacks:PackIconMaterial Kind="ChessKing"
                                                    Width="26" Height="26"
                                                    Foreground="#E0E0E0"/>
                        <TextBlock Text=" Joueur Noir"
                                   FontSize="18"
                                   Foreground="#FFBC85"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Nom :" Width="120" Foreground="#BDBDBD"/>
                        <TextBlock Text="{Binding NomJoueurNoir}" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                        <TextBlock Text="Temps :" Width="120" Foreground="#BDBDBD"/>
                        <TextBlock Text="{Binding TempsJoueurNoir}"
                                   Foreground="#FFA860"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- STATUT + HISTORIQUE -->
        <StackPanel Grid.Row="2">

            <TextBlock Text="{Binding TourActuel}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#81C784"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding StatutPartie}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#FFC97E"
                       Margin="0 0 0 15"
                       HorizontalAlignment="Center"/>

            <Border Background="#2A2A2A"
                    CornerRadius="10"
                    Padding="12">

                <ScrollViewer Height="270" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HistoriqueCoups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#E0E0E0"
                                           FontFamily="Consolas"
                                           Margin="4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Border>
        </StackPanel>

        <!-- BOUTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 20">

            <Button Content="Nouvelle Partie"
                    Command="{Binding CommandeNouvellePartie}"
                    Margin="8"/>

            <Button Content="Annuler"
                    Command="{Binding CommandeAnnulerCoup}"
                    Margin="8"/>

            <Button Content="Nulle"
                    Command="{Binding CommandeProposerNulle}"
                    Margin="8"/>

            <Button Content="Abandonner"
                    Command="{Binding CommandeAbandonner}"
                    Foreground="White"
                    Background="#D84343"
                    Margin="8"/>

            <Button Content="Sauvegarder"
                    Command="{Binding CommandeSauvegarder}"
                    Margin="8"/>

            <Button Content="Charger"
                    Command="{Binding CommandeCharger}"
                    Margin="8"/>
        </StackPanel>

    </Grid>
</UserControl>
