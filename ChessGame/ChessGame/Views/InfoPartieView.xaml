<UserControl x:Class="ChessGame.Views.InfoPartieView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="300">

    <Border Style="{StaticResource PanneauPrincipal}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Titre -->
                <TextBlock Text="Informations de la partie"
                           Style="{StaticResource TexteTitre}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Joueurs -->
                <Border Style="{StaticResource PanneauPrincipal}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="♔ Joueur Blanc"
                                   Style="{StaticResource TexteNormal}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding NomJoueurBlanc}"
                                   Style="{StaticResource TexteNormal}"
                                   Margin="10,0,0,5"/>
                        <TextBlock Text="{Binding TempsJoueurBlanc}"
                                   Style="{StaticResource TexteInfo}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanneauPrincipal}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="♚ Joueur Noir"
                                   Style="{StaticResource TexteNormal}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding NomJoueurNoir}"
                                   Style="{StaticResource TexteNormal}"
                                   Margin="10,0,0,5"/>
                        <TextBlock Text="{Binding TempsJoueurNoir}"
                                   Style="{StaticResource TexteInfo}"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Statut -->
                <Border Style="{StaticResource PanneauPrincipal}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Statut"
                                   Style="{StaticResource TexteNormal}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding StatutPartie}"
                                   Style="{StaticResource TexteNormal}"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding TourActuel}"
                                   Style="{StaticResource TexteInfo}"
                                   Margin="10,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Historique des coups -->
                <Border Style="{StaticResource PanneauPrincipal}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Historique"
                                   Style="{StaticResource TexteNormal}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ListBox ItemsSource="{Binding HistoriqueCoups}"
                                 Style="{StaticResource ListeHistorique}"
                                 Height="200"
                                 Background="{StaticResource FondPrincipalBrush}"
                                 BorderBrush="{StaticResource BordureBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{StaticResource PoliceMonospace}"
                                               Foreground="{StaticResource TextePrincipalBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Boutons d'action -->
                <StackPanel Margin="0,10,0,0">
                    <Button Content="Nouvelle Partie"
                            Style="{StaticResource BoutonPrincipal}"
                            Command="{Binding CommandeNouvellePartie}"
                            Margin="0,0,0,5"/>

                    <Button Content="Annuler Coup"
                            Style="{StaticResource BoutonSecondaire}"
                            Command="{Binding CommandeAnnulerCoup}"
                            Margin="0,0,0,5"/>

                    <Button Content="Proposer Nulle"
                            Style="{StaticResource BoutonSecondaire}"
                            Command="{Binding CommandeProposerNulle}"
                            Margin="0,0,0,5"/>

                    <Button Content="Abandonner"
                            Style="{StaticResource BoutonSecondaire}"
                            Command="{Binding CommandeAbandonner}"
                            Margin="0,0,0,5"/>

                    <Separator Margin="0,10" Background="{StaticResource BordureBrush}"/>

                    <Button Content="Sauvegarder"
                            Style="{StaticResource BoutonSecondaire}"
                            Command="{Binding CommandeSauvegarder}"
                            Margin="0,0,0,5"/>

                    <Button Content="Charger"
                            Style="{StaticResource BoutonSecondaire}"
                            Command="{Binding CommandeCharger}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
